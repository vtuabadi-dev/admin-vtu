# ============================================================
# VTU OPERASIONAL — .gitignore
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js build
.next/
out/

# Production build
build/
dist/

# TypeScript
tsconfig.tsbuildinfo
*.tsbuildinfo

# Environment — NEVER commit
.env
.env.local
.env.*.local
.env.production
.env.development
.env.docker
.env.staging

# Testing
coverage/
.vitest/
.vitest/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker — runtime artifacts only
.docker/
DockerData/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Runtime storage — generated files only (root only, not src/server/storage)
/storage/
uploads/
exports/

# Temp
tmp/
temp/
*.tmp

# Cache
.cache/
.turbo/

# Prisma
prisma/dev.db
prisma/dev.db-journal

# ZIP / archives
*.zip
*.tar.gz
*.rar

.vercel

.vercel
