# ============================================================
# VTU OPERASIONAL — Konfigurasi Environment
# ============================================================
# Cara pakai:
#   1. Copy file ini ke .env  (cp .env.example .env)
#   2. Isi semua yang ada tanda <<<< >>>>
#   3. Jangan commit .env ke git!
# ============================================================


# ╔══════════════════════════════════════════════════════════╗
# ║  1. DATABASE                                             ║
# ╚══════════════════════════════════════════════════════════╝

DATABASE_URL=postgresql://vtu_admin:<<<< GANTI_PASSWORD_DATABASE >>>>@postgres:5432/vtu_operasional

POSTGRES_DB=vtu_operasional
POSTGRES_USER=vtu_admin
POSTGRES_PASSWORD=<<<< GANTI_PASSWORD_DATABASE >>>>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432


# ╔══════════════════════════════════════════════════════════╗
# ║  2. REDIS                                                ║
# ╚══════════════════════════════════════════════════════════╝

REDIS_URL=redis://:<<<< GANTI_PASSWORD_REDIS >>>>@redis:6379

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<<<< GANTI_PASSWORD_REDIS >>>>


# ╔══════════════════════════════════════════════════════════╗
# ║  3. AUTH / SECURITY                                      ║
# ╚══════════════════════════════════════════════════════════╝
# Generate: openssl rand -hex 32  (jalankan di terminal)

AUTH_SECRET=<<<< GENERATE_DENGAN_OPENSSL_RAND_HEX_32 >>>>
AUTH_URL=<<<< URL_APLIKASI_ANDA >>>>  (contoh: https://vtu.example.com)
NEXTAUTH_SECRET=<<<< GENERATE_DENGAN_OPENSSL_RAND_HEX_32 >>>>
NEXTAUTH_URL=<<<< URL_APLIKASI_ANDA >>>>  (contoh: https://vtu.example.com)
AUTH_TRUST_HOST=true


# ╔══════════════════════════════════════════════════════════╗
# ║  4. OCR — Engine Pembaca Dokumen (Google Vision)         ║
# ╚══════════════════════════════════════════════════════════╝
#
# Pilih salah satu:
#
#   Opsi A — Tesseract lokal (default, tanpa API, tanpa biaya):
#           OCR_PROVIDER=tesseract
#           (biarkan yang lain dikosongi)
#
#   Opsi B — Google Cloud Vision API:
#           OCR_PROVIDER=google-vision
#           taruh API key Google Vision di bawah
#

OCR_PROVIDER=tesseract

# ── OPSI B: GOOGLE CLOUD VISION ────────────────────────────
# Isi hanya kalau pilih OCR_PROVIDER=google-vision
# Dapatkan API key dari: https://console.cloud.google.com/apis/credentials
#
# Format 1 key:
#   GOOGLE_VISION_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Format 2 key atau lebih (dipisah koma, auto-rotasi kalau rate limit):
#   GOOGLE_VISION_API_KEY=AIzaSyDxxxxxxxx,AIzaSyEyyyyyyyy
#
# Format banyak key (satu per baris):
#   GOOGLE_VISION_API_KEY=AIzaSyDxxxxxxxx
#   GOOGLE_VISION_API_KEY_2=AIzaSyEyyyyyyyy
#   GOOGLE_VISION_API_KEY_3=AIzaSyFzzzzzzzz

GOOGLE_VISION_API_KEY=<<<< TARUH_API_KEY_GOOGLE_VISION_DISINI >>>>


# ╔══════════════════════════════════════════════════════════╗
# ║  5. NOTIFIKASI — WhatsApp / Telegram / Email             ║
# ╚══════════════════════════════════════════════════════════╝
#
# Pilih salah satu:
#
#   Opsi A — Mock (development, tidak kirim apa-apa):
#           NOTIFICATION_PROVIDER=mock
#
#   Opsi B — Console (debug, tampil di log):
#           NOTIFICATION_PROVIDER=console
#

NOTIFICATION_PROVIDER=mock

# ── WHATSAPP GATEWAY ───────────────────────────────────────
# Isi kalau sudah punya WhatsApp Business API

# WHATSAPP_API_TOKEN=<<<< TOKEN_WHATSAPP_API >>>>
# WHATSAPP_PHONE_ID=<<<< PHONE_ID_WHATSAPP >>>>

# ── TELEGRAM GATEWAY ───────────────────────────────────────
# Isi kalau sudah punya Telegram Bot

# TELEGRAM_BOT_TOKEN=<<<< TOKEN_BOT_TELEGRAM >>>>

# ── EMAIL GATEWAY ──────────────────────────────────────────
# Isi kalau sudah punya SMTP / Resend

# SMTP_HOST=<<<< HOST_SMTP >>>>
# SMTP_PORT=587
# SMTP_USER=<<<< USERNAME_SMTP >>>>
# SMTP_PASS=<<<< PASSWORD_SMTP >>>>
# SMTP_FROM=noreply@vtu.example.com


# ╔══════════════════════════════════════════════════════════╗
# ║  6. STORAGE                                              ║
# ╚══════════════════════════════════════════════════════════╝

STORAGE_PATH=/storage

# ── S3 (opsional, kosongkan untuk local storage) ──────────
# AWS_REGION=<<<< REGION_S3 >>>>
# S3_BUCKET=<<<< NAMA_BUCKET_S3 >>>>
# AWS_ACCESS_KEY_ID=<<<< ACCESS_KEY_S3 >>>>
# AWS_SECRET_ACCESS_KEY=<<<< SECRET_KEY_S3 >>>>


# ╔══════════════════════════════════════════════════════════╗
# ║  7. APPLICATION                                          ║
# ╚══════════════════════════════════════════════════════════╝

NODE_ENV=production
NEXT_PUBLIC_APP_NAME=VTU Operasional
NEXT_PUBLIC_APP_URL=<<<< URL_APLIKASI_ANDA >>>>


# ╔══════════════════════════════════════════════════════════╗
# ║  8. LAINNYA (opsional)                                   ║
# ╚══════════════════════════════════════════════════════════╝

# LOG_LEVEL=info
# BACKUP_RETENTION_DAYS=30
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
