# ============================================================
# TRAVEL OPERATIONAL SYSTEM — Production Environment
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=VTU Operasional
NEXT_PUBLIC_APP_URL=https://vtu.example.com

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vtu_operasional
POSTGRES_USER=vtu_admin
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Database connection string (built from above)
DATABASE_URL=postgresql://vtu_admin:change-me-to-a-strong-password@postgres:5432/vtu_operasional

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-to-a-strong-redis-password
REDIS_URL=redis://:change-me-to-a-strong-redis-password@redis:6379

# --- Storage ---
# Base path for persistent file storage (inside container)
STORAGE_PATH=/storage

# --- Security ---
# Next.js session / JWT signing secret
NEXTAUTH_SECRET=generate-a-random-64-char-string-here
# API key for internal service communication
INTERNAL_API_KEY=generate-another-random-key-here

# --- External Services (future) ---
# WhatsApp Business API
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=

# OCR Service (future)
# OCR_SERVICE_URL=http://ocr-worker:8080

# --- Reverse Proxy ---
# Set if behind Nginx Proxy Manager / Cloudflare
TRUST_PROXY=true

# --- Optional: Rate Limiting ---
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
