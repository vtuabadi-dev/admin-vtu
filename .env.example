# ============================================================
# VTU OPERASIONAL — Konfigurasi Environment
# ============================================================
# Cara pakai:
#   1. Copy file ini ke .env  (cp .env.example .env)
#   2. Isi semua yang ada tanda <<<< >>>>
#   3. Jangan commit .env ke git!
# ============================================================


# ╔══════════════════════════════════════════════════════════╗
# ║  1. DATABASE — Supabase PostgreSQL                       ║
# ╚══════════════════════════════════════════════════════════╝
#
# Supabase menyediakan 2 connection string:
#
#   DATABASE_URL  → Pooler (PgBouncer, port 6543)
#                   Untuk aplikasi — pakai ?pgbouncer=true
#                   Contoh: postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
#   DIRECT_URL    → Direct connection (port 5432)
#                   Untuk migration & seed — TANPA pgBouncer
#                   Contoh: postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# Cara dapatkan:
#   Supabase Dashboard → Settings → Database → Connection String
#   Pilih "Pooler" → Session mode → copy DATABASE_URL
#   Pilih "Direct" → copy DIRECT_URL

DATABASE_URL=<<<< SUPABASE_POOLER_URL_DENGAN_pgbouncer=true >>>>
DIRECT_URL=<<<< SUPABASE_DIRECT_URL_TANPA_pgbouncer >>>>


# ╔══════════════════════════════════════════════════════════╗
# ║  3. AUTH / SECURITY                                      ║
# ╚══════════════════════════════════════════════════════════╝
# Generate: openssl rand -hex 32  (jalankan di terminal)

AUTH_SECRET=<<<< GENERATE_DENGAN_OPENSSL_RAND_HEX_32 >>>>
AUTH_URL=<<<< URL_APLIKASI_ANDA >>>>  (contoh: https://vtu.example.com)
NEXTAUTH_SECRET=<<<< GENERATE_DENGAN_OPENSSL_RAND_HEX_32 >>>>
NEXTAUTH_URL=<<<< URL_APLIKASI_ANDA >>>>  (contoh: https://vtu.example.com)
AUTH_TRUST_HOST=true


# ╔══════════════════════════════════════════════════════════╗
# ║  3. OCR — Google Vision API                              ║
# ╚══════════════════════════════════════════════════════════╝
# OCR dokumen dan flyer paket memakai API eksternal Google Vision.
# Dipakai untuk ekstraksi Paspor, KTP, KK, dan teks flyer paket.
#
# Provider utama:
#   OCR_PROVIDER=google-vision
#   GOOGLE_VISION_API_KEY=<<<< API_KEY_GOOGLE_VISION >>>>
#
# Opsional jika punya OCR gateway sendiri:
#   OCR_PROVIDER=external-api
#   OCR_API_URL=https://ocr-service.example.com/api/ocr
#   OCR_API_KEY=<<<< API_KEY_OCR_SERVICE >>>>

OCR_PROVIDER=google-vision
GOOGLE_VISION_API_KEY=<<<< API_KEY_GOOGLE_VISION >>>>

# ── CUSTOM OCR GATEWAY (opsional) ──────────────────────────
OCR_API_URL=
OCR_API_KEY=
OCR_API_HEADER_NAME=Authorization
OCR_API_HEADER_PREFIX=Bearer
OCR_API_TIMEOUT=30000
OCR_API_MODEL=


# ╔══════════════════════════════════════════════════════════╗
# ║  5. NOTIFIKASI — WhatsApp / Telegram / Email             ║
# ╚══════════════════════════════════════════════════════════╝
#
# Pilih salah satu:
#
#   Opsi A — Mock (development, tidak kirim apa-apa):
#           NOTIFICATION_PROVIDER=mock
#
#   Opsi B — Console (debug, tampil di log):
#           NOTIFICATION_PROVIDER=console
#

NOTIFICATION_PROVIDER=mock

# ── WHATSAPP GATEWAY ───────────────────────────────────────
# Isi kalau sudah punya WhatsApp Business API

# WHATSAPP_API_TOKEN=<<<< TOKEN_WHATSAPP_API >>>>
# WHATSAPP_PHONE_ID=<<<< PHONE_ID_WHATSAPP >>>>

# ── TELEGRAM GATEWAY ───────────────────────────────────────
# Isi kalau sudah punya Telegram Bot

# TELEGRAM_BOT_TOKEN=<<<< TOKEN_BOT_TELEGRAM >>>>

# ── EMAIL GATEWAY ──────────────────────────────────────────
# Isi kalau sudah punya SMTP / Resend

# SMTP_HOST=<<<< HOST_SMTP >>>>
# SMTP_PORT=587
# SMTP_USER=<<<< USERNAME_SMTP >>>>
# SMTP_PASS=<<<< PASSWORD_SMTP >>>>
# SMTP_FROM=noreply@vtu.example.com


# ╔══════════════════════════════════════════════════════════╗
# ║  6. STORAGE                                              ║
# ╚══════════════════════════════════════════════════════════╝

STORAGE_PATH=/storage

# ── S3 (opsional, kosongkan untuk local storage) ──────────
# AWS_REGION=<<<< REGION_S3 >>>>
# S3_BUCKET=<<<< NAMA_BUCKET_S3 >>>>
# AWS_ACCESS_KEY_ID=<<<< ACCESS_KEY_S3 >>>>
# AWS_SECRET_ACCESS_KEY=<<<< SECRET_KEY_S3 >>>>


# ╔══════════════════════════════════════════════════════════╗
# ║  7. APPLICATION                                          ║
# ╚══════════════════════════════════════════════════════════╝

NODE_ENV=production
NEXT_PUBLIC_APP_NAME=VTU Operasional
NEXT_PUBLIC_APP_URL=<<<< URL_APLIKASI_ANDA >>>>


# ╔══════════════════════════════════════════════════════════╗
# ║  8. LAINNYA (opsional)                                   ║
# ╚══════════════════════════════════════════════════════════╝

# LOG_LEVEL=info
# BACKUP_RETENTION_DAYS=30
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
